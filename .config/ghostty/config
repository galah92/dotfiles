# theme = dark:koda_dark,light:koda_light
theme = dark:kodansi_dark,light:kodansi_light

font-family = Maple Mono
font-family = JetBrains Mono
font-feature = -calt, -liga, -dlig  # Disable ligatures
cursor-style = block
cursor-style-blink = false

# Force shell to use ghostty cursor style
shell-integration-features = no-cursor

macos-titlebar-proxy-icon = hidden

adjust-cell-height = 8%

# Allow pasting over Tmux inside SSH sessions without confirmation
clipboard-read = allow
clipboard-write = allow

# Show notifications when commands finish when the window is unfocused
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
